{
  "name": "studentflow",
  "version": "0.1.0",
  "private": true,
  "engines": {
    "node": ">=22.0.0"
  },
  "scripts": {
    "dev": "next dev",
    "build": "next build",
    "start": "next start --hostname 0.0.0.0",
    "typecheck": "tsc --noEmit",
    "format": "prettier --write . && prettier --write --parser html \"**/*.svg\"",
    "format:check": "prettier --check . && prettier --check --parser html \"**/*.svg\"",
    "db:migrate": "tsx scripts/supabase-migrate.ts",
    "db:seed": "tsx scripts/supabase-seed.ts",
    "db:seed:force": "tsx scripts/supabase-seed.ts --force",
    "imagekit:seed": "tsx scripts/imagekit-seed.ts",
    "setup": "npm run db:migrate && tsx scripts/setup-supabase.ts",
    "render:build": "npm run setup && npm run build"
  },
  "dependencies": {
    "@imagekit/nodejs": "^7.8.0",
    "@supabase/supabase-js": "^2.108.2",
    "bcryptjs": "^3.0.3",
    "dotenv": "^17.4.2",
    "lucide-react": "^0.468.0",
    "next": "15.5.19",
    "postgres": "^3.4.9",
    "react": "19.1.1",
    "react-dom": "19.1.1",
    "zod": "^3.24.2"
  },
  "devDependencies": {
    "@types/node": "^22.13.10",
    "@types/react": "^19.0.10",
    "@types/react-dom": "^19.0.4",
    "autoprefixer": "^10.4.20",
    "postcss": "^8.5.3",
    "prettier": "^3.8.4",
    "prettier-plugin-sql": "^0.20.0",
    "tailwindcss": "^3.4.17",
    "tsx": "^4.19.3",
    "typescript": "^5.8.2"
  }
}
